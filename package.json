{
  "name": "auto-readme",
  "version": "1.0.0",
  "type": "module",
  "description": "A CLI that analyzes any repository and generates a professional README.md automatically",
  "main": "dist/index.js",
  "bin": {
    "auto-readme": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js"
  },
  "keywords": ["readme", "cli", "generator", "markdown", "docs"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0"
  }
}
